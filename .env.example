# NDEB Login Credentials
NDEB_USERNAME=your_email@example.com
NDEB_PASSWORD=your_password

# Chrome Profile (use your real profile to skip reCAPTCHA)
# Run: ls ~/Library/Application\ Support/Google/Chrome/ | grep Profile
# Then set to your profile folder name, e.g. "Profile 1"
CHROME_PROFILE=

# Slot Checker Settings
CHECK_INTERVAL_SECONDS=30
HEADLESS_MODE=false

# Location Filters (comma-separated cities to EXCLUDE)
EXCLUDED_LOCATIONS=New York,Los Angeles,Washington,Pennsylvania,Michigan
